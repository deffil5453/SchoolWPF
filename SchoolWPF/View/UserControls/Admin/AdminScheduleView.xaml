<UserControl x:Class="SchoolWPF.View.UserControls.Admin.AdminScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SchoolWPF.View.UserControls.Admin"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="📋 Управление расписанием" Style="{StaticResource PageTitle}"/>

        <!-- Панель добавления/редактирования (упрощённая сетка) -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="60"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto" MinWidth="60"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto" MinWidth="60"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Класс + Предмет + Учитель -->
                <TextBlock Grid.Column="0" Grid.Row="0" Text="Класс:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" Grid.Row="0" ItemsSource="{Binding Classes}" DisplayMemberPath="ClassName" 
                          SelectedItem="{Binding SelectedClass}" Style="{StaticResource ModernComboBox}"/>

                <TextBlock Grid.Column="3" Grid.Row="0" Text="Предмет:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="4" Grid.Row="0" ItemsSource="{Binding Subjects}" DisplayMemberPath="Name" 
                          SelectedItem="{Binding SelectedSubject}" Style="{StaticResource ModernComboBox}"/>

                <TextBlock Grid.Column="6" Grid.Row="0" Text="Учитель:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="6" Grid.Row="0" ItemsSource="{Binding Teachers}" 
                          SelectedItem="{Binding SelectedTeacher}" Style="{StaticResource ModernComboBox}" Margin="70,0,0,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} {1} {2}">
                                        <Binding Path="LastName"/>
                                        <Binding Path="FirstName"/>
                                        <Binding Path="MiddleName"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Row 2: День + Урок + Кнопки -->
                <TextBlock Grid.Column="0" Grid.Row="2" Text="День:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" Grid.Row="2" ItemsSource="{Binding Days}" SelectedItem="{Binding SelectedDay}" 
                          Style="{StaticResource ModernComboBox}"/>

                <TextBlock Grid.Column="3" Grid.Row="2" Text="Урок:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="4" Grid.Row="2" ItemsSource="{Binding Lessons}" SelectedItem="{Binding SelectedLesson}" 
                          Style="{StaticResource ModernComboBox}" Width="70"/>

                <!-- Кнопки: Добавить / Редактировать (справа) -->
                <StackPanel Grid.Column="6" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✏️ Редактировать" Style="{StaticResource AccentButton}"
                            Command="{Binding EditEntryCommand}" Width="150" Margin="0,0,10,0"
                            IsEnabled="{Binding IsAdmin}"/>
                    <Button Content="➕ Добавить" Style="{StaticResource SuccessButton}"
                            Command="{Binding AddEntryCommand}" Width="110"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица расписания -->
        <DataGrid Grid.Row="2" Style="{StaticResource ModernDataGrid}"
                  ItemsSource="{Binding ClassSchedule}" SelectedItem="{Binding SelectedSchedule}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Урок №" Binding="{Binding LessonNumber}" Width="0.8*"/>
                <DataGridTextColumn Header="День" Binding="{Binding DayOfWeekDisplay}" Width="1*"/>
                <DataGridTextColumn Header="Предмет" Binding="{Binding Subject.Name}" Width="1.5*"/>
                <DataGridTextColumn Header="Учитель" Width="2*">
                    <DataGridTextColumn.Binding>
                        <MultiBinding StringFormat="{}{0} {1} {2}">
                            <Binding Path="Teacher.LastName"/>
                            <Binding Path="Teacher.FirstName"/>
                            <Binding Path="Teacher.MiddleName"/>
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопка удаления -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="🗑 Удалить выбранный" Style="{StaticResource DangerButton}"
                    Command="{Binding DeleteEntryCommand}" Width="160"/>
        </StackPanel>
    </Grid>
</UserControl>
