<UserControl x:Class="SchoolWPF.View.UserControls.Admin.ClassesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SchoolWPF.View.UserControls.Admin"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{StaticResource BackgroundBrush}"
             >
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок + кнопка -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="🏫 Классы" Style="{StaticResource PageTitle}"/>
            <Button Content="➕ Добавить класс" Style="{StaticResource SuccessButton}"
                    Command="{Binding AddCommand}" HorizontalAlignment="Right" Width="160"/>
        </Grid>

        <!-- Список классов -->
        <DataGrid Grid.Row="1" Style="{StaticResource ModernDataGrid}"
                  ItemsSource="{Binding Classes}" SelectedItem="{Binding SelectedClass}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название класса" Binding="{Binding ClassName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
