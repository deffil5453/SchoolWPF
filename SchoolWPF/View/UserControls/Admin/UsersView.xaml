<UserControl x:Class="SchoolWPF.View.UserControls.Admin.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SchoolWPF.View.UserControls.Admin"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="👥 Управление пользователями" Style="{StaticResource PageTitle}"/>

        <!-- Форма создания (аккуратная сетка) -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="80"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto" MinWidth="80"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto" MinWidth="70"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Логин + Пароль + Роль -->
                <TextBlock Grid.Column="0" Grid.Row="0" Text="Логин:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding NewLogin}" Style="{StaticResource ModernTextBox}" Margin="0,0,15,0"/>

                <TextBlock Grid.Column="2" Grid.Row="0" Text="Пароль:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <PasswordBox Grid.Column="3" Grid.Row="0" x:Name="PwdBox" Margin="0,0,15,0"/>

                <TextBlock Grid.Column="4" Grid.Row="0" Text="Роль:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="5" Grid.Row="0" ItemsSource="{Binding Roles}" DisplayMemberPath="Name" 
                          SelectedItem="{Binding SelectedRole}" Style="{StaticResource ModernComboBox}"/>

                <!-- Row 2: Учитель + Кнопка -->
                <!-- Учитель: ФИО через DataTemplate -->
                <TextBlock Grid.Row="2" Text="Учитель:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,0,0"/>
                <ComboBox Grid.Row="2" Grid.ColumnSpan="3" 
          ItemsSource="{Binding Teachers}" 
          SelectedItem="{Binding SelectedTeacher}" 
          Style="{StaticResource ModernComboBox}" 
          Margin="69,0,40,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} {1} {2}">
                                        <Binding Path="LastName"/>
                                        <Binding Path="FirstName"/>
                                        <Binding Path="MiddleName"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Grid.Column="5" Grid.Row="2" Grid.ColumnSpan="2" Content="➕ Создать" Style="{StaticResource SuccessButton}"
                        Command="{Binding CreateUserCommand}" CommandParameter="{Binding ElementName=PwdBox}"
                        HorizontalAlignment="Right" Width="110"/>
            </Grid>
        </Border>

        <!-- Список пользователей -->
        <DataGrid Grid.Row="2" Style="{StaticResource ModernDataGrid}"
                  ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="1.2*"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding Role.Name}" Width="1*"/>
                <DataGridTextColumn Header="Учитель" Binding="{Binding Teacher.LastName}" Width="1.5*"/>
                <DataGridTextColumn Header="Активен" Binding="{Binding IsActive}" Width="0.8*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопка удаления -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="🗑 Удалить выбранного" Style="{StaticResource DangerButton}"
                    Command="{Binding DeleteUserCommand}" Width="170"/>
        </StackPanel>
    </Grid>
</UserControl>
