<UserControl x:Class="SchoolWPF.View.UserControls.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SchoolWPF.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="📊 Статистика посещаемости" Style="{StaticResource PageTitle}"/>

        <!-- Панель фильтров -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="60"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto" MinWidth="60"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto" MinWidth="50"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Класс:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Classes}"
                          DisplayMemberPath="ClassName"
                          SelectedItem="{Binding SelectedClass}"
                          Style="{StaticResource ModernComboBox}"/>

                <TextBlock Grid.Column="3" Text="Месяц:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="4" ItemsSource="{Binding Months}" 
                          SelectedItem="{Binding SelectedMonthName}" 
                          Style="{StaticResource ModernComboBox}"/>

                <TextBlock Grid.Column="6" Text="Год:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="7" ItemsSource="{Binding Years}" 
                          SelectedItem="{Binding SelectedYear}" 
                          Style="{StaticResource ModernComboBox}"/>

                <Button Grid.Column="8" Content="📥 Сформировать отчёт"
                        Command="{Binding GenerateReportCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Width="160" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Таблица отчёта -->
        <DataGrid Grid.Row="2" Style="{StaticResource ModernDataGrid}"
                  ItemsSource="{Binding ReportRows}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="1.2*" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="1.2*"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="1.2*"/>
                <DataGridTextColumn Header="Всего уроков" Binding="{Binding TotalLessons}" Width="0.9*" />
                <DataGridTextColumn Header="Н" Binding="{Binding AbsentCount}" Width="0.6*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#C62828"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Б" Binding="{Binding SickCount}" Width="0.6*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#EF6C00"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="У" Binding="{Binding ExcusedCount}" Width="0.6*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#2E7D32"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Посещаемость" Binding="{Binding AttendancePercent, StringFormat={}{0:F1}%}" Width="1.1*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
