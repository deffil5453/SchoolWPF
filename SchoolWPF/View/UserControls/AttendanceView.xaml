<UserControl x:Class="SchoolWPF.View.UserControls.AttendanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SchoolWPF.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{StaticResource BackgroundBrush}">
    <UserControl.Resources>
        <Style x:Key="StatusComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="📓 Журнал посещаемости" Style="{StaticResource PageTitle}"/>

        <!-- Панель фильтров -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="60"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto" MinWidth="60"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto" MinWidth="60"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Класс:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Classes}" 
                          DisplayMemberPath="ClassName" 
                          SelectedItem="{Binding SelectedClass}" 
                          Style="{StaticResource ModernComboBox}"/>

                <TextBlock Grid.Column="3" Text="Дата:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <DatePicker Grid.Column="4" SelectedDate="{Binding SelectedDate}" 
                             
                            SelectedDateFormat="Short"/>

                <TextBlock Grid.Column="6" Text="Урок:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="7" ItemsSource="{Binding LessonNumbers}" 
                          SelectedItem="{Binding SelectedLessonNumber}" 
                          Style="{StaticResource ModernComboBox}"/>

                <Button Grid.Column="8" Content="🔍 Показать" 
                        Command="{Binding ShowJournalCommand}" 
                        Style="{StaticResource PrimaryButton}" 
                        Width="120" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Таблица журнала -->
        <DataGrid Grid.Row="2" Style="{StaticResource ModernDataGrid}"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  SelectedItem="{Binding SelectedRow}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="1.3*" IsReadOnly="True" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="1.3*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="1.3*" IsReadOnly="True"/>

                <DataGridTemplateColumn Header="Статус" Width="1.2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding Path=DataContext.StatusOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding Status, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      Style="{StaticResource ModernComboBox}"
                                      Width="90" HorizontalAlignment="Left">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="Н">
                                                <Setter Property="Background" Value="#FFEBEE"/>
                                                <Setter Property="Foreground" Value="#C62828"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="Б">
                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                <Setter Property="Foreground" Value="#EF6C00"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="У">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель сохранения -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,15,0,0" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{Binding SelectedLessonNumber, StringFormat='{}{0}-й урок'}" 
                           Style="{StaticResource FieldLabel}" 
                           VerticalAlignment="Center" Margin="0,0,20,0"/>
                <Button Content="💾 Сохранить отметки" 
                        Command="{Binding SaveCommand}" 
                        Style="{StaticResource SuccessButton}" 
                        Width="160" Height="40" FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
