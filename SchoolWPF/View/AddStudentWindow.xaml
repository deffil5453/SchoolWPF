<Window x:Class="SchoolWPF.View.AddStudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SchoolWPF.View"
        mc:Ignorable="d"
        Title="Добавить ученика" Height="460" Width="420" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20,20,20,4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Фамилия -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Фамилия" Margin="0,0,0,5"/>
            <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Height="25"/>
        </StackPanel>

        <!-- Имя -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Имя" Margin="0,0,0,5"/>
            <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Height="25"/>
        </StackPanel>

        <!-- ✅ Отчество (НОВОЕ ПОЛЕ) -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Отчество" Margin="0,0,0,5"/>
            <TextBox Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}" Height="25"/>
        </StackPanel>

        <!-- Дата рождения (сдвинуто вниз) -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Дата рождения" Margin="0,0,0,5"/>
            <DatePicker SelectedDate="{Binding BirthDate, UpdateSourceTrigger=PropertyChanged}" Height="25"/>
        </StackPanel>

        <!-- Пол -->
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Пол" Margin="0,0,0,5"/>
            <ComboBox ItemsSource="{Binding Genders}" SelectedItem="{Binding SelectedGender}" Height="25"/>
        </StackPanel>

        <!-- Класс -->
        <StackPanel Grid.Row="5" Margin="0,0,0,10">
            <TextBlock Text="Класс" Margin="0,0,0,5"/>
            <ComboBox ItemsSource="{Binding Classes}" 
                      DisplayMemberPath="ClassName" 
                      SelectedValuePath="Id" 
                      SelectedValue="{Binding SelectedClassId}" 
                      Height="32"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Center" Width="210" Height="32" Margin="0,10,0,0">
            <Button Content="Отмена" Command="{Binding CancelCommand}" Width="100" Height="32" Margin="0,0,10,0" 
                     Background="red" Foreground="White" FontWeight="Bold"/>
            <Button Content="Сохранить" Command="{Binding SaveCommand}" Width="100" Height="32" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
